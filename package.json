    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@tanstack/react-query": "^5.62.0",
    "drizzle-orm": "^0.38.2",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
