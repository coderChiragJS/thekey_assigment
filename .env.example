# ── Local development (default) ────────────────────────────────────────────
# Path to the SQLite database file, created by `npm run db:setup`.
DATABASE_URL=./forum.db

# ── Hosted deployment (e.g. Vercel + Turso) — optional ──────────────────────
# For a serverless deploy the DB can't be a local file. Point DATABASE_URL at a
# hosted libsql/Turso database and supply its auth token. Leave these unset for
# local development.
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token
